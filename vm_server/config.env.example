# MQTT Configuration
# MQTT broker address - defaults to localhost since Mosquitto runs on the same VM
# Note: The NEMO backend needs to know the VM's IP address (e.g., 10.0.0.31) to connect to Mosquitto
#       This is configured on the NEMO backend side, not here
MQTT_BROKER=localhost
# MQTT ports (broker listeners; ESP32s connect to MQTT_PORT_ESP32, NEMO backend to MQTT_PORT)
MQTT_PORT_ESP32=1883
MQTT_PORT=1886
# HMAC key for NEMO↔broker authentication (generated by setup.sh if not set).
# When set, the VM server only accepts MQTT messages from NEMO that include a valid HMAC.
# Share the key with the NEMO backend and keep it secret. See README for payload format.
MQTT_HMAC_KEY=
# Broker login (set by setup.sh if you enable MQTT broker authentication)
MQTT_USERNAME=
MQTT_PASSWORD=
# Require username/password (no anonymous). When false, allow_anonymous is false in mosquitto.conf.
# setup.sh sets this when you enable broker auth; set to false to require credentials.
MQTT_ALLOW_ANONYMOUS=false

# Display Configuration
# Timezone offset in hours from UTC (e.g., -7 for Pacific Time, -5 for Eastern Time)
TIMEZONE_OFFSET_HOURS=-7

# Maximum character length for user names on display (truncate if longer)
MAX_NAME_LENGTH=13

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
