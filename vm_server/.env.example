# API Configuration
API_URL=https://nemo.stanford.edu/api/tool_status/
NEMO_TOKEN=your_nemo_api_token_here

# MQTT Configuration (LAN Distribution)
MQTT_BROKER=localhost
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=

# Polling Configuration
POLL_INTERVAL=30

# Network Configuration
BIND_ADDRESS=0.0.0.0

# ESP32 Display Configuration
ESP32_DISPLAY_TOOLS=woollam
MQTT_USE_SSL=true
